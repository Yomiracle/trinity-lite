# Optional local state overrides.
# Do not put real API keys in files committed to git.

TRINITY_LITE_HOME="$HOME/.trinity-lite"
TRINITY_LITE_DB="$HOME/.trinity-lite/trinity_lite.db"

# Restrict task cwd execution to these roots. Separate multiple roots with ":" on macOS/Linux.
TRINITY_LITE_ALLOWED_ROOTS="$HOME"
